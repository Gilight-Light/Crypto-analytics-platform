# Copy to `.env` (gitignored) and fill in values. Never commit `.env`.

# Stream scope
BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt,bnbusdt,xrpusdt

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_HOST=localhost:29092
KAFKA_TOPIC_RAW_TRADES=raw_trades

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold
MINIO_BUCKET_CHECKPOINTS=checkpoints
MINIO_BUCKET_WAREHOUSE=warehouse

# Postgres (shared metadata backend for Hive / Airflow / Superset)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_pw
POSTGRES_DB=platform

# Hive Metastore
HIVE_METASTORE_URI=thrift://hive-metastore:9083
HIVE_METASTORE_DB=hive

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_pw
CLICKHOUSE_DB=realtime

# Airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_FERNET_KEY=

# Trino
TRINO_USER=trino

# Superset
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# External APIs
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crypto-analytics-platform/0.1
COINGECKO_API_KEY=
NEWSAPI_KEY=
